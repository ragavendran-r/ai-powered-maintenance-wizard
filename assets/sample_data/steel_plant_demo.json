  "documents": [
    {
      "id": "DOC-RM-SOP-01",
      "source_type": "sop",
      "equipment_id": "RM-DRIVE-01",
      "title": "Hot Strip Mill Main Drive Vibration SOP",
      "content": "If drive end vibration exceeds 7.1 mm/s, inspect bearing housing temperature, lubrication condition, coupling alignment, foundation bolts, and load changes. Reduce load if vibration remains above alarm threshold for more than 15 minutes."
    },
    {
      "id": "DOC-RM-MAN-02",
      "source_type": "manual",
      "equipment_id": "RM-DRIVE-01",
      "title": "Main Drive Motor Bearing Maintenance Manual",
      "content": "Bearing temperature above 85 C combined with rising vibration indicates possible lubrication breakdown, bearing wear, or misalignment. Recommended action is controlled inspection during planned stoppage unless vibration reaches trip criteria."
    },
    {
      "id": "DOC-BF-SOP-01",
      "source_type": "sop",
      "equipment_id": "BF-BLOWER-02",
      "title": "Blast Furnace Blower Pressure Variance SOP",
      "content": "Pressure variance above 10 percent should trigger inspection of inlet guide vane response, actuator calibration, filter restriction, and surge margin. Notify the furnace supervisor when high variance persists for two samples."
    },
    {
      "id": "DOC-SPARES-01",
