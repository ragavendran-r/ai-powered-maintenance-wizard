  "documents": [
    {
      "id": "DOC-RM-SOP-01",
      "source_type": "sop",
      "equipment_id": "RM-DRIVE-01",
      "title": "Hot Strip Mill Main Drive Vibration SOP",
      "content": "If drive end vibration exceeds 7.1 mm/s, inspect bearing housing temperature, lubrication condition, coupling alignment, foundation bolts, and load changes. Reduce load if vibration remains above alarm threshold for more than 15 minutes."
    },
    {
      "id": "DOC-RM-MAN-02",
      "source_type": "manual",
      "equipment_id": "RM-DRIVE-01",
      "title": "Main Drive Motor Bearing Maintenance Manual",
      "content": "Bearing temperature above 85 C combined with rising vibration indicates possible lubrication breakdown, bearing wear, or misalignment. Recommended action is controlled inspection during planned stoppage unless vibration reaches trip criteria."
    },
    {
      "id": "DOC-BF-SOP-01",
      "source_type": "sop",
      "equipment_id": "BF-BLOWER-02",
      "title": "Blast Furnace Blower Pressure Variance SOP",
      "content": "Pressure variance above 10 percent should trigger inspection of inlet guide vane response, actuator calibration, filter restriction, and surge margin. Notify the furnace supervisor when high variance persists for two samples."
    },
    {
      "id": "DOC-HYD-SOP-01",
      "source_type": "sop",
      "equipment_id": "HYD-SYS-04",
      "title": "Hydraulic System Temperature And Pulsation SOP",
      "content": "If hydraulic oil temperature exceeds 75 C or pressure pulsation exceeds 8 percent, inspect heat exchanger flow, return filter differential pressure, servo valve spool response, pump case drain flow, and reservoir aeration. Reduce correction duty cycles until oil temperature stabilizes."
    },
    {
      "id": "DOC-HYD-MAN-02",
      "source_type": "manual",
      "equipment_id": "HYD-SYS-04",
      "title": "Hydraulic Power Unit Troubleshooting Manual",
      "content": "Pressure pulsation combined with oil temperature rise indicates possible pump wear, relief valve instability, contamination, or air ingress. Recommended corrective action is oil sampling, filter replacement, servo valve inspection, and controlled pump swash plate check."
    },
    {
      "id": "DOC-CRANE-SOP-01",
      "source_type": "sop",
      "equipment_id": "OH-CRANE-05",
      "title": "Overhead Crane Hoist Current And Brake Temperature SOP",
      "content": "Stop heavy lifts and park the crane if hoist motor current exceeds 180 A or hoist brake temperature exceeds 90 C. Inspect brake air gap, shoe wear, wire rope condition, limit switch response, and contactor heating before returning to production service."
    },
    {
      "id": "DOC-CRANE-MAN-02",
      "source_type": "manual",
      "equipment_id": "OH-CRANE-05",
      "title": "Main Hoist Brake And Motor Maintenance Manual",
      "content": "Rising hoist current with brake temperature above normal can indicate brake drag, shoe glazing, overloaded lift cycle, motor winding heating, or contactor resistance. Verify load path, perform brake torque test, and inspect wire rope before the next ladle movement."
    },
    {
      "id": "DOC-SPARES-01",
      "source_type": "spares",
      "equipment_id": null,
      "title": "Critical Spare Procurement Guidance",
      "content": "For process-critical equipment, zero stock with lead time greater than 14 days should increase maintenance priority and trigger procurement escalation."
    }
  ]
}
