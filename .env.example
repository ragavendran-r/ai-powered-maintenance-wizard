# Backend
LLM_PROVIDER=mock
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
LLM_TIMEOUT_SECONDS=15
LLM_STREAM_TIMEOUT_SECONDS=60
LLM_STRUCTURED_MAX_TOKENS=300
LLM_TEXT_MAX_TOKENS=600
LLM_USE_ACTIVE_LEARNING_MODEL=true
DATABASE_PATH=backend/data/maintenance_wizard.db

# LM Studio local OpenAI-compatible server
# Recommended local model: Qwen2.5 7B Instruct GGUF, Q4_K_M quantization.
# Start LM Studio's local server on http://localhost:1234/v1, then use:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=lm-studio-local
# OPENAI_BASE_URL=http://localhost:1234/v1
# OPENAI_MODEL=qwen2.5-7b-instruct
# LLM_TIMEOUT_SECONDS=15
# LLM_STREAM_TIMEOUT_SECONDS=60
# LLM_STRUCTURED_MAX_TOKENS=300
# LLM_TEXT_MAX_TOKENS=600

# Local authentication and role-based authorization
AUTH_ENABLED=true
JWT_SECRET_KEY=maintenance-wizard-local-dev-secret-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
AUTH_SEED_DEMO_USERS=true

# Optional NATS JetStream IoT streaming ingestion
STREAMING_ENABLED=false
NATS_URL=nats://localhost:4222
NATS_STREAM=MW_IOT
NATS_CONSUMER=maintenance-wizard-ingestor
NATS_SUBJECT_PREFIX=steelplant.iot
NATS_DLQ_SUBJECT=steelplant.iot.dlq
NATS_AUTH_TOKEN=
NATS_CREDENTIALS_PATH=
NATS_TLS_ENABLED=false
NATS_BATCH_SIZE=20
NATS_ACK_WAIT_SECONDS=30
NATS_MAX_DELIVER=3
NATS_RECONNECT_TIME_WAIT_SECONDS=2
NATS_MAX_RECONNECT_ATTEMPTS=60

# Async learning/tuning jobs over NATS JetStream
LEARNING_ASYNC_ENABLED=true
LEARNING_NATS_STREAM=MW_LEARNING
LEARNING_NATS_CONSUMER=maintenance-wizard-learning-worker
LEARNING_NATS_SUBJECT_PREFIX=maintenance.learning
LEARNING_NATS_DLQ_SUBJECT=maintenance.learning.dlq
LEARNING_ARTIFACT_DIR=backend/data/learning_artifacts
LEARNING_ARTIFACT_STORE=filesystem
LEARNING_ARTIFACT_S3_BUCKET=
LEARNING_ARTIFACT_S3_PREFIX=maintenance-wizard/learning
LEARNING_ARTIFACT_S3_ENDPOINT_URL=
LEARNING_ARTIFACT_S3_REGION=us-east-1
LEARNING_ARTIFACT_RETENTION_DAYS=0
LEARNING_ARTIFACT_CLEANUP_ENABLED=false
LEARNING_PEFT_TRAINER_COMMAND=
LEARNING_PEFT_TRAINER_TIMEOUT_SECONDS=900
LEARNING_PEFT_OUTPUT_DIR=backend/data/learning_adapters
LEARNING_RUNTIME_DEPLOYMENT_REQUIRED=true
LEARNING_RUNTIME_DEPLOYER_DEFAULT=manual
LEARNING_RUNTIME_DEPLOYMENT_TIMEOUT_SECONDS=15
# Optional bundled local Qwen/SLM PEFT trainer template. Install dependencies in
# a separate .venv-peft first; normal app tests do not require them.
# LEARNING_PEFT_TRAINER_COMMAND=.venv-peft/bin/python scripts/peft/train_qwen_lora.py
# LEARNING_PEFT_TRAINER_TIMEOUT_SECONDS=7200
# MW_PEFT_MODEL_SOURCE=Qwen/Qwen2.5-7B-Instruct
# MW_PEFT_QUANTIZATION=4bit
# MW_PEFT_MAX_SEQ_LENGTH=2048

# Production RAG vector database
RAG_VECTOR_STORE=qdrant
RAG_QDRANT_URL=http://localhost:6333
RAG_QDRANT_COLLECTION=maintenance_wizard_documents
RAG_QDRANT_COLLECTION_ALIAS=
RAG_QDRANT_API_KEY=
RAG_VECTOR_TIMEOUT_SECONDS=2
RAG_EMBEDDING_PROVIDER=deterministic_hash
RAG_EMBEDDING_MODEL=maintenance-hash-v1
RAG_EMBEDDING_VERSION=1
RAG_EMBEDDING_DIMENSIONS=64
RAG_EMBEDDING_DISTANCE=Cosine
RAG_EMBEDDING_BASE_URL=
RAG_EMBEDDING_API_KEY=
RAG_EMBEDDING_TIMEOUT_SECONDS=10
RAG_EMBEDDING_BATCH_SIZE=32

# Frontend
VITE_API_BASE=http://localhost:8000
