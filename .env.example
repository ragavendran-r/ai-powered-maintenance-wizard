# Backend
LLM_PROVIDER=mock
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_RCA_DRAFT_TIMEOUT_SECONDS=45
LLM_RCA_DRAFT_MAX_TOKENS=700
LLM_RCA_DRAFT_RESPONSE_FORMAT=json_schema
LLM_RCA_DRAFT_STREAM_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
LLM_TIMEOUT_SECONDS=15
LLM_STREAM_TIMEOUT_SECONDS=60
LLM_STRUCTURED_MAX_TOKENS=300
LLM_TEXT_MAX_TOKENS=600
LLM_USE_ACTIVE_LEARNING_MODEL=true
ASSISTANT_RUNTIME=pydantic_ai
# Use prompted structured output by default for llama.cpp/Qwen local serving.
# Set ASSISTANT_OUTPUT_MODE=tool_output only after confirming OpenAI-style tool calls work reliably.
ASSISTANT_OUTPUT_MODE=prompted
ASSISTANT_HISTORY_LIMIT=12
DATABASE_PATH=backend/data/maintenance_wizard.db

# Local OpenAI-compatible server
# For adapter serving, use llama.cpp on http://127.0.0.1:8080/v1.
# LM Studio remains an optional base/fused-model runtime on http://localhost:1234/v1.
# LLM_PROVIDER=openai
# OPENAI_API_KEY=local-runtime
# OPENAI_BASE_URL=http://127.0.0.1:8080/v1
# OPENAI_MODEL=maintenance-wizard-qwen-lora-LJOB-7B7B7B7B7B7B
# LLM_TIMEOUT_SECONDS=15
# LLM_STREAM_TIMEOUT_SECONDS=60
# LLM_STRUCTURED_MAX_TOKENS=300
# LLM_TEXT_MAX_TOKENS=600
# ASSISTANT_OUTPUT_MODE=prompted
# LLM_RCA_DRAFT_TIMEOUT_SECONDS=45
# LLM_RCA_DRAFT_MAX_TOKENS=700
# LLM_RCA_DRAFT_RESPONSE_FORMAT=json_schema
# LLM_RCA_DRAFT_STREAM_ENABLED=true

# Local authentication and role-based authorization
AUTH_ENABLED=true
JWT_SECRET_KEY=maintenance-wizard-local-dev-secret-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
AUTH_SEED_DEMO_USERS=true

# Optional NATS JetStream IoT streaming ingestion
STREAMING_ENABLED=false
NATS_URL=nats://localhost:4222
NATS_STREAM=MW_IOT
NATS_CONSUMER=maintenance-wizard-ingestor
NATS_SUBJECT_PREFIX=steelplant.iot
NATS_DLQ_SUBJECT=steelplant.iot.dlq
NATS_AUTH_TOKEN=
NATS_CREDENTIALS_PATH=
NATS_TLS_ENABLED=false
NATS_BATCH_SIZE=20
NATS_ACK_WAIT_SECONDS=30
NATS_MAX_DELIVER=3
NATS_RECONNECT_TIME_WAIT_SECONDS=2
NATS_MAX_RECONNECT_ATTEMPTS=60

# Async learning/tuning jobs over NATS JetStream
LEARNING_ASYNC_ENABLED=true
LEARNING_NATS_STREAM=MW_LEARNING
LEARNING_NATS_CONSUMER=maintenance-wizard-learning-worker
LEARNING_NATS_SUBJECT_PREFIX=maintenance.learning
LEARNING_NATS_DLQ_SUBJECT=maintenance.learning.dlq
LEARNING_ARTIFACT_DIR=backend/data/learning_artifacts
LEARNING_ARTIFACT_STORE=filesystem
LEARNING_ARTIFACT_S3_BUCKET=
LEARNING_ARTIFACT_S3_PREFIX=maintenance-wizard/learning
LEARNING_ARTIFACT_S3_ENDPOINT_URL=
LEARNING_ARTIFACT_S3_REGION=us-east-1
LEARNING_ARTIFACT_RETENTION_DAYS=0
LEARNING_ARTIFACT_CLEANUP_ENABLED=false
LEARNING_PEFT_TRAINER_COMMAND=
LEARNING_PEFT_TRAINER_TIMEOUT_SECONDS=900
LEARNING_PEFT_OUTPUT_DIR=backend/data/learning_adapters
LEARNING_RUNTIME_DEPLOYMENT_REQUIRED=true
LEARNING_RUNTIME_DEPLOYER_DEFAULT=llama_cpp
LEARNING_ADAPTER_DEPLOYER_COMMAND="bash scripts/peft/deploy_llama_cpp_adapter.sh"
LEARNING_ADAPTER_DEPLOYER_TIMEOUT_SECONDS=120
LEARNING_RUNTIME_DEPLOYMENT_TIMEOUT_SECONDS=15
# Optional bundled local Qwen/SLM PEFT trainer template. Install dependencies in
# a separate .venv-peft first; normal app tests do not require them.
# LEARNING_PEFT_TRAINER_COMMAND=.venv-peft/bin/python scripts/peft/train_qwen_lora.py
# LEARNING_PEFT_TRAINER_TIMEOUT_SECONDS=7200
# MW_PEFT_MODEL_SOURCE=Qwen/Qwen2.5-7B-Instruct
# MW_PEFT_QUANTIZATION=4bit
# MW_PEFT_MAX_SEQ_LENGTH=2048
# Default llama.cpp adapter deployment hook. Start from a GGUF base model and
# a GGUF LoRA adapter generated from the trained PEFT adapter output.
LLAMA_CPP_BASE_MODEL_PATH=/Users/ragaven/.lmstudio/models/Qwen/Qwen2.5-7B-Instruct-GGUF/qwen2.5-7b-instruct-q4_k_m-00001-of-00002.gguf
LLAMA_CPP_HF_REPO=Qwen/Qwen2.5-7B-Instruct-GGUF:Q4_K_M
LLAMA_CPP_HF_FILE=
LLAMA_CPP_ALIAS=maintenance-wizard-qwen-lora-LJOB-7B7B7B7B7B7B
LLAMA_CPP_ADAPTER_GGUF_PATH=
MW_ADAPTER_ARTIFACT_URI=backend/data/learning_adapters/LJOB-7B7B7B7B7B7B/adapter
LLAMA_CPP_HOST=127.0.0.1
LLAMA_CPP_PORT=8080
LLAMA_CPP_EXTRA_ARGS=
# Example for a matching Qwen2.5 7B Instruct GGUF base model if the local file path above is not available:
# LLAMA_CPP_HF_REPO=Qwen/Qwen2.5-7B-Instruct-GGUF
# LLAMA_CPP_HF_FILE=qwen2.5-7b-instruct-q4_k_m-00001-of-00002.gguf
# Optional converter when LLAMA_CPP_ADAPTER_GGUF_PATH is empty and the trainer
# output is a PEFT adapter directory. Point this at llama.cpp/convert_lora_to_gguf.py.
LLAMA_CPP_CONVERT_LORA_SCRIPT=
# Optional LM Studio deployment hook. This loads a fused/imported model under
# the trained adapter alias before the backend probes http://localhost:1234/v1.
# LEARNING_RUNTIME_DEPLOYER_DEFAULT=lm_studio
# LEARNING_ADAPTER_DEPLOYER_COMMAND="bash scripts/peft/deploy_lmstudio_fused_model.sh"
# MW_ADAPTER_DEPLOY_MODEL_SOURCE=/path/to/fused-adapter-model.gguf

# Production RAG vector database
RAG_VECTOR_STORE=qdrant
RAG_QDRANT_URL=http://localhost:6333
RAG_QDRANT_COLLECTION=maintenance_wizard_documents
RAG_QDRANT_COLLECTION_ALIAS=
RAG_QDRANT_API_KEY=
RAG_VECTOR_TIMEOUT_SECONDS=2
RAG_EMBEDDING_PROVIDER=deterministic_hash
RAG_EMBEDDING_MODEL=maintenance-hash-v1
RAG_EMBEDDING_VERSION=1
RAG_EMBEDDING_DIMENSIONS=64
RAG_EMBEDDING_DISTANCE=Cosine
RAG_EMBEDDING_BASE_URL=
RAG_EMBEDDING_API_KEY=
RAG_EMBEDDING_TIMEOUT_SECONDS=10
RAG_EMBEDDING_BATCH_SIZE=32

# Frontend
VITE_API_BASE=http://localhost:8000
