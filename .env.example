# Backend
LLM_PROVIDER=mock
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
LLM_TIMEOUT_SECONDS=15
LLM_STRUCTURED_MAX_TOKENS=300
LLM_TEXT_MAX_TOKENS=600
DATABASE_PATH=backend/data/maintenance_wizard.db

# LM Studio local OpenAI-compatible server
# Recommended local model: Qwen2.5 7B Instruct GGUF, Q4_K_M quantization.
# Start LM Studio's local server on http://localhost:1234/v1, then use:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=lm-studio-local
# OPENAI_BASE_URL=http://localhost:1234/v1
# OPENAI_MODEL=qwen2.5-7b-instruct
# LLM_TIMEOUT_SECONDS=15
# LLM_STRUCTURED_MAX_TOKENS=300
# LLM_TEXT_MAX_TOKENS=600

# Local authentication and role-based authorization
AUTH_ENABLED=true
JWT_SECRET_KEY=maintenance-wizard-local-dev-secret-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
AUTH_SEED_DEMO_USERS=true

# Optional NATS JetStream IoT streaming ingestion
STREAMING_ENABLED=false
NATS_URL=nats://localhost:4222
NATS_STREAM=MW_IOT
NATS_CONSUMER=maintenance-wizard-ingestor
NATS_SUBJECT_PREFIX=steelplant.iot
NATS_DLQ_SUBJECT=steelplant.iot.dlq
NATS_AUTH_TOKEN=
NATS_CREDENTIALS_PATH=
NATS_TLS_ENABLED=false
NATS_BATCH_SIZE=20
NATS_ACK_WAIT_SECONDS=30
NATS_MAX_DELIVER=3
NATS_RECONNECT_TIME_WAIT_SECONDS=2
NATS_MAX_RECONNECT_ATTEMPTS=60

# Frontend
VITE_API_BASE=http://localhost:8000
